rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return role() == "admin";
    }

    function isCommercial() {
      return role() == "comercial";
    }

    function isViewer() {
      return role() == "visor";
    }

    function assignedToMe(resourceData) {
      return resourceData.comercialAsignado == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if signedIn() && (isAdmin() || request.auth.uid == uid);
      allow create, update, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if signedIn() && (isAdmin() || isViewer() || (isCommercial() && assignedToMe(resource.data)));
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isCommercial()
          && assignedToMe(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["notas", "estado", "etiquetas", "updatedAt"]));
    }

    match /campaigns/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /messageTemplates/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /messages/{id} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /messageQueue/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /doNotContact/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /tasks/{id} {
      allow read: if signedIn() && (isAdmin() || isViewer() || resource.data.assignedTo == request.auth.uid);
      allow create, update: if isAdmin()
        || (isCommercial() && request.resource.data.assignedTo == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /demos/{id} {
      allow read: if signedIn() && (isAdmin() || isViewer() || resource.data.assignedTo == request.auth.uid);
      allow create, update: if isAdmin()
        || (isCommercial() && request.resource.data.assignedTo == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /assets/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if signedIn() && id != "whatsappSecrets";
      allow write: if isAdmin() && id != "whatsappSecrets";
    }
  }
}
